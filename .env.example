# Required: PostgreSQL connection (Neon, Vercel Postgres, or local Docker)
# Never use file:./dev.db — this project uses PostgreSQL only.
# Local Docker: docker compose up -d
DATABASE_URL="postgresql://eleve:eleve@localhost:5432/eleve?schema=public"
DIRECT_URL="postgresql://eleve:eleve@localhost:5432/eleve?schema=public"

# Neon production (from Vercel dashboard — never commit real values):
# DATABASE_URL="postgresql://...@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://...@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Required: admin authentication (env only — never commit real values)
ADMIN_PASSWORD="change-me-to-a-strong-password"
AUTH_SECRET="generate-a-random-32-character-secret-here-minimum"

# Optional: workspace ID for multi-business ÉLEVÉ OS (default: default)
# WORKSPACE_ID="default"
# WORKSPACE_NAME="ÉLEVÉ Visuals"
# AI_MULTIMODAL="0"
# Create a PUBLIC Blob store in Vercel Storage and connect it to the project.
# Vercel auto-injects BLOB_READ_WRITE_TOKEN — do not use a Private store for portfolio images.
# BLOB_READ_WRITE_TOKEN=""
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# Optional: Plausible Analytics (privacy-friendly external analytics)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="elevevisuals.com"

# Optional: canonical site URL for metadata
# NEXT_PUBLIC_SITE_URL="https://elevevisuals.com"

# Optional: AI intelligence layer (ÉLEVÉ Control — OpenRouter)
# AI_PROVIDER="openrouter"       # openrouter (default) | ollama (local dev)
# OPENROUTER_API_KEY=""          # Required for AI features — get at https://openrouter.ai/keys
# OPENROUTER_MODEL="qwen/qwen3-32b" # Preserved fallback after live free-model routing
# OPENROUTER_FALLBACK_MODELS="deepseek/deepseek-chat-v3-0324,meta-llama/llama-3.3-70b-instruct,mistralai/mistral-small-3.1-24b-instruct"
# AI_MAX_RETRIES="2"
# AI_MAX_MODEL_ATTEMPTS="8"
# AI_RETRY_DELAY_MS="600"
# AI_MIN_INTERVAL_MS="120"
# AI_REQUEST_TIMEOUT_MS="45000"
# AI_CACHE_TTL_MS="300000"
# OLLAMA_BASE_URL="http://127.0.0.1:11434"   # Optional local fallback
# OLLAMA_MODEL="llama3.2"

# Cron (required in production for /api/cron/digest)
# CRON_SECRET="generate-a-random-secret"

# E2E tests (Playwright)
# PLAYWRIGHT_BASE_URL="http://localhost:3000"
# E2E_ADMIN_PASSWORD="same-as-ADMIN_PASSWORD-for-local-tests"
