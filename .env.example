# Required: PostgreSQL connection (Neon, Vercel Postgres, or local Docker)
DATABASE_URL="postgresql://eleve:eleve@localhost:5432/eleve?schema=public"
# For Neon/Vercel Postgres with a pooler, use the direct (non-pooled) URL as DATABASE_URL,
# or set DIRECT_URL to the direct connection and keep the pooler URL in DATABASE_URL.
# DIRECT_URL="postgresql://eleve:eleve@localhost:5432/eleve?schema=public"

# Required: admin authentication (env only — never commit real values)
ADMIN_PASSWORD="change-me-to-a-strong-password"
AUTH_SECRET="generate-a-random-32-character-secret-here-minimum"

# Optional: Vercel Blob for admin image uploads in production
# BLOB_READ_WRITE_TOKEN=""
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# Optional: Plausible Analytics (privacy-friendly external analytics)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="elevevisuals.com"

# Optional: canonical site URL for metadata
# NEXT_PUBLIC_SITE_URL="https://elevevisuals.com"

# E2E tests (Playwright)
# PLAYWRIGHT_BASE_URL="http://localhost:3000"
# E2E_ADMIN_PASSWORD="same-as-ADMIN_PASSWORD-for-local-tests"
