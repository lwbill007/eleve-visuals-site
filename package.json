{
  "name": "eleve-visuals",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:setup": "prisma migrate deploy && prisma db seed",
    "db:studio": "prisma studio",
    "db:health": "tsx scripts/db-health-check.ts",
    "verify:truth": "tsx scripts/verify-truth-layer.ts",
    "verify:audit": "tsx scripts/stabilization-audit.ts",
    "audit:enterprise": "tsx scripts/enterprise-audit.ts",
    "audit:os": "tsx scripts/admin-os-audit.ts",
    "verify": "tsc --noEmit && next lint && tsx scripts/verify-truth-layer.ts && tsx scripts/ai-regression-smoke.ts",
    "test:ai": "tsx scripts/ai-regression-smoke.ts",
    "db:audit:production": "tsx scripts/production-api-audit.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test e2e/manual-smoke.spec.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@vercel/blob": "^2.4.1",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.16.0",
    "jose": "^6.0.11",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "web-push": "^3.6.7",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
