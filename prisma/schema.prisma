generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PortfolioItem {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  subtitle          String   @default("")
  category          String
  client            String?
  year              String
  description       String
  creativeProcess   String   @default("")
  image             String?
  imageAlt          String   @default("")
  heroImage         String?
  heroImageAlt      String   @default("")
  aspectRatio       String   @default("landscape")
  featured          Boolean  @default(false)
  portfolioFeatured Boolean  @default(false)
  archived          Boolean  @default(false)
  sortOrder         Int      @default(0)
  gallery           String   @default("[]")
  btsGallery        String   @default("[]")
  videos            String   @default("[]")
  deliverables      String   @default("[]")
  credits           String   @default("[]")
  relatedServices   String   @default("[]")
  seoTitle          String   @default("")
  seoDescription    String   @default("")
  published         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([portfolioFeatured])
}

model Service {
  id             String  @id @default(cuid())
  slug           String  @unique
  title          String
  tagline        String
  description    String
  forWhom        String
  includes       String  @default("[]")
  deliverables   String  @default("[]")
  faqs           String  @default("[]")
  startingPrice  String
  turnaround     String  @default("")
  image          String?
  imageAlt       String  @default("")
  bannerImage    String?
  thumbnailImage String?
  featured       Boolean @default(false)
  sortOrder      Int     @default(0)
  published      Boolean @default(true)
  archived       Boolean @default(false)

  @@index([featured])
}

model Testimonial {
  id        String  @id @default(cuid())
  quote     String
  name      String
  role      String
  image     String?
  imageAlt  String  @default("")
  featured  Boolean @default(false)
  sortOrder Int     @default(0)
  published Boolean @default(true)
}

model SiteContent {
  key   String @id
  value String
}

model Submission {
  id               String   @id @default(cuid())
  type             String
  data             String
  status           String   @default("new")
  notes            String   @default("")
  read             Boolean  @default(false)
  starred          Boolean  @default(false)
  sessionVolumeId  String?
  ipAddress        String   @default("")
  userAgent        String   @default("")
  contactEmail     String   @default("")
  readAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([type, status])
  @@index([type, createdAt])
  @@index([sessionVolumeId, type])
  @@index([starred, type])
  @@index([contactEmail])
}

model ActivityLog {
  id        String   @id @default(cuid())
  actor     String   @default("admin")
  action    String
  target    String   @default("")
  details   String   @default("")
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String   @unique
  filename  String   @default("")
  alt       String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model NotificationLog {
  id           String   @id @default(cuid())
  submissionId String?
  formType     String
  channel      String
  provider     String   @default("")
  recipient    String   @default("")
  subject      String   @default("")
  preview      String   @default("")
  status       String   @default("pending")
  error        String   @default("")
  attempts     Int      @default(0)
  dedupeKey    String   @default("")
  read         Boolean  @default(false)
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
  @@index([channel, status])
  @@index([dedupeKey, createdAt])
  @@index([submissionId])
  @@index([archived, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  label     String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  ip        String
  route     String
  createdAt DateTime @default(now())

  @@index([ip, route, createdAt])
}

model AnalyticsEvent {
  id             String   @id @default(cuid())
  type           String
  path           String   @default("")
  referrer       String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  conversionType String?
  sessionId      String?
  createdAt      DateTime @default(now())

  @@index([type, createdAt])
  @@index([path, createdAt])
}

model SessionVolume {
  id                  String    @id @default(cuid())
  volumeNumber        Int
  title               String
  slug                String    @unique
  theme               String    @default("")
  subtitle            String    @default("")
  synopsis            String    @default("")
  posterImage         String?
  posterImageAlt      String    @default("")
  bannerImage         String?
  bannerImageAlt      String    @default("")
  moodBoard           String    @default("[]")
  gallery             String    @default("[]")
  btsGallery          String    @default("[]")
  videos              String    @default("[]")
  status              String    @default("draft")
  genre               String    @default("")
  year                String    @default("")
  sessionDate         String    @default("")
  sessionTime         String    @default("")
  location            String    @default("")
  city                String    @default("")
  capacity            String    @default("")
  category            String    @default("")
  creativeDirector    String    @default("")
  directorsNote       String    @default("")
  galleryDelivery     String    @default("")
  dressCode           String    @default("")
  runtime             String    @default("")
  mood                String    @default("")
  season              String    @default("")
  difficulty          String    @default("")
  colorPalette        String    @default("[]")
  inspirations        String    @default("[]")
  testimonials        String    @default("[]")
  requirements        String    @default("[]")
  timeline            String    @default("[]")
  applicationDeadline DateTime?
  teaserVideoUrl      String?
  featuredMediaId     String?
  playlistUrl         String?
  interviews          String    @default("[]")
  audio               String    @default("[]")
  productionNotes     String    @default("")
  callSheet           String?
  creativeBrief       String    @default("")
  wardrobeGuide       String?
  sponsors            String    @default("[]")
  resources           String    @default("[]")
  faqs                String    @default("[]")
  featured            Boolean   @default(false)
  published           Boolean   @default(false)
  showApplyButton     Boolean   @default(true)
  archived            Boolean   @default(false)
  applicationSettings String    @default("{}")
  seoTitle            String    @default("")
  seoDescription      String    @default("")
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  cast                CastMember[]

  @@index([published, status])
  @@index([featured])
  @@index([volumeNumber])
}

model CastMember {
  id                   String   @id @default(cuid())
  volumeId             String
  volume               SessionVolume @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  fullName             String
  stageName            String   @default("")
  slug                 String   @default("")
  role                 String   @default("model")
  profilePhoto         String?
  additionalPhotos     String   @default("[]")
  bio                  String   @default("")
  instagram            String   @default("")
  tiktok               String   @default("")
  website              String   @default("")
  portfolioLink        String   @default("")
  city                 String   @default("")
  status               String   @default("confirmed")
  featured             Boolean  @default(false)
  isAlumni             Boolean  @default(false)
  featuredAlumni       Boolean  @default(false)
  notes                String   @default("")
  futureCollaborations String   @default("")
  enableProfile        Boolean  @default(false)
  awards               String   @default("[]")
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([volumeId, sortOrder])
  @@index([slug])
  @@index([featuredAlumni])
}
